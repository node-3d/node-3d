{
	"name": "node-3d",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "Node3D superproject and local workspace.",
	"workspaces": [
		"packages/addon-tools",
		"packages/deps-bullet",
		"packages/deps-freeimage",
		"packages/deps-labsound",
		"packages/deps-opengl",
		"packages/deps-qmlui",
		"packages/deps-qt-core",
		"packages/deps-qt-gui",
		"packages/deps-qt-qml",
		"packages/deps-uiohook",
		"packages/segfault",
		"packages/webaudio",
		"packages/webgl",
		"packages/bullet",
		"packages/cuda",
		"packages/glfw",
		"packages/image",
		"packages/iohook",
		"packages/opencl",
		"packages/steam-api",
		"packages/qml",
		"packages/core",
		"packages/plugin-bullet",
		"packages/plugin-qml",
		"packages/plugin-webaudio",
		"packages/qml-fontawesome",
		"packages/qml-colorhelpers",
		"packages/qml-themedui"
	],
	"scripts": {
		"packages:update": "git submodule update --init --recursive",
		"packages:graph": "node scripts/workspace-graph.ts",
		"packages:lint": "npm run build:ci --workspace @node-3d/addon-tools && npm run lint:all --workspaces --if-present",
		"packages:test": "npm run test:ci --workspaces --if-present",
		"lint:oxlint": "oxlint .",
		"build:ci": "npm run build:ci --workspaces --if-present",
		"lint:ts": "npm run lint:ts --workspaces --if-present",
		"lint:all": "npm run lint:oxlint && npm run lint:ts && npm run lint:gypi",
		"lint:gypi": "npm run lint:gypi --workspaces --if-present",
		"format:ts": "npm run build:ci --workspace @node-3d/addon-tools && oxfmt -c ./oxfmt.config.ts --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
		"format:ts:ci": "npm run build:ci --workspace @node-3d/addon-tools && oxfmt -c ./oxfmt.config.ts --check --no-error-on-unmatched-pattern \"**/*.{js,jsx,ts,tsx}\"",
		"format": "npm run format:ts && npm run format:ts --workspaces --if-present && npm run format:src --workspaces --if-present",
		"format:ci": "npm run format:ts:ci && npm run format:ts:ci --workspaces --if-present && npm run format:src:ci --workspaces --if-present"
	},
	"engines": {
		"node": ">=24.13.0",
		"npm": ">=11.6.2"
	},
	"devDependencies": {
		"@rslib/core": "0.23.2",
		"@types/node": "24.13.2",
		"@types/three": "0.174.0",
		"oxlint": "1.72.0",
		"tslib": "2.8.1",
		"three": "0.174.0",
		"oxfmt": "0.57.0",
		"typescript": "7.0.2"
	},
	"overrides": {
		"@types/three": "0.174.0",
		"three": "0.174.0"
	}
}
